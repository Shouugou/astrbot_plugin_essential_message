{
  "enabled": {
    "description": "启用插件调度",
    "type": "bool",
    "default": true,
    "hint": "关闭后所有群订阅都不会自动发送。"
  },
  "default_daily_count": {
    "description": "默认每次发送条数",
    "type": "int",
    "default": 1,
    "hint": "群内开启订阅时未指定条数，则使用该值。实际范围会限制在 1-10。"
  },
  "default_send_time": {
    "description": "默认每日发送时间",
    "type": "string",
    "default": "09:00",
    "hint": "固定时间，格式 HH:MM，例如 09:00。群内可用 /精华时间 单独设置。"
  },
  "check_interval_seconds": {
    "description": "调度检查间隔秒数",
    "type": "int",
    "default": 30
  },
  "message_prefix": {
    "description": "图片卡片标题",
    "type": "string",
    "default": "今日群精华"
  },
  "subscription_group_ids": {
    "type": "template_list",
    "description": "订阅群聊",
    "hint": "添加需要每日发送群精华的 QQ 群，可设置每群的发送条数和时间。",
    "templates": {
      "subscription": {
        "name": "订阅群聊",
        "items": {
          "group_id": {
            "description": "QQ 群号",
            "type": "string"
          },
          "count": {
            "description": "每次发送条数",
            "type": "int",
            "default": 1
          },
          "send_time": {
            "description": "每日发送时间 (HH:MM)",
            "type": "string",
            "default": "09:00"
          }
        }
      }
    }
  }
}
